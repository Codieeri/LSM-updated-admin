MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>
PORT=3001

# Cloudinary Storage
CLOUDINARY_URL=cloudinary://<API_KEY>:<API_SECRET>@<CLOUD_NAME>
CLOUDINARY_CLOUD_NAME=<CLOUD_NAME>
CLOUDINARY_API_KEY=<API_KEY>
CLOUDINARY_API_SECRET=<API_SECRET>

# ── HR "New Candidate" Notifications ────────────────────────────────────────
# Default HR contact used the first time notification settings are created.
# These can also be changed later from Admin Panel > Notifications.
HR_NOTIFY_EMAIL=riyasonara079@gmail.com
HR_NOTIFY_PHONE=9512506193

# Email delivery — pick ONE of the following (checked in this order):
# 1) Google Apps Script Webhook
APPS_SCRIPT_WEBHOOK_URL=
APPS_SCRIPT_SHARED_SECRET=
# 2) SMTP (Nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="LocalSM Hiring Team <hiring@localsm.com>"
# 3) Resend API
RESEND_API_KEY=

# Personal message (SMS/WhatsApp) delivery via Twilio — optional.
# Leave blank to skip sending the personal message (email still sends).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_CHANNEL=sms
